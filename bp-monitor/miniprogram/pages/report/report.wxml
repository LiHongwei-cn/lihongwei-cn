<wxs src="../../utils/md.wxs" module="md" />

<view class="container">
  <view class="week-nav card">
    <view class="week-arrow" bindtap="prevWeek">‹ 上一周</view>
    <view class="week-label">{{weekStart}} ~ {{weekEnd}}</view>
    <view class="week-arrow {{weekOffset >= 0 ? 'disabled' : ''}}" bindtap="nextWeek">下一周 ›</view>
  </view>

  <view class="loading-text" wx:if="{{loading}}">加载中...</view>

  <view wx:elif="{{report}}">
    <view class="card">
      <text class="section-title">概览</text>
      <view class="overview-grid">
        <view class="overview-item">
          <text class="overview-value">{{report.avgSystolic}}/{{report.avgDiastolic}}</text>
          <text class="overview-label">平均血压</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.readingCount}}次</text>
          <text class="overview-label">测量次数</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.complianceRate}}%</text>
          <text class="overview-label">依从性</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.timeInRange}}%</text>
          <text class="overview-label">达标率</text>
        </view>
      </view>
    </view>

    <view class="card" wx:if="{{report.morningAvgSys || report.eveningAvgSys}}">
      <text class="section-title">早晚对比</text>
      <view class="compare-row">
        <view class="compare-item">
          <text class="compare-value">{{report.morningAvgSys || '--'}}</text>
          <text class="compare-label">晨峰收缩压</text>
        </view>
        <view class="compare-item">
          <text class="compare-value">{{report.eveningAvgSys || '--'}}</text>
          <text class="compare-label">晚间收缩压</text>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="section-title">波动</text>
      <view class="volatility-row">
        <text>标准差：收缩压 {{report.stdSystolic}} / 舒张压 {{report.stdDiastolic}}</text>
        <text class="volatility-detail">最高 {{report.maxSystolic}}/{{report.maxDiastolic}} 最低 {{report.minSystolic}}/{{report.minDiastolic}}</text>
      </view>
    </view>

    <!-- AI 趋势分析 —— 分区卡片渲染 -->
    <view wx:if="{{report.trendSummary}}">
      <view class="card ai-card-header">
        <view class="ai-header-icon">🤖</view>
        <view class="ai-header-text">
          <text class="ai-header-title">AI 健康周报</text>
          <text class="ai-header-sub">基于本周 {{report.readingCount}} 次测量数据智能生成</text>
        </view>
      </view>

      <block wx:for="{{md.parseSections(report.trendSummary).sections}}" wx:key="index">
        <view class="card ai-section">
          <view class="ai-section-head">
            <text class="ai-section-icon">{{item.icon}}</text>
            <text class="ai-section-title">{{item.title}}</text>
          </view>
          <view class="ai-section-body">
            <block wx:for="{{item.lines}}" wx:for-item="line" wx:key="index2">
              <view class="ai-line">
                <text class="ai-dot">·</text>
                <view class="ai-line-parts">
                  <block wx:for="{{line.parts}}" wx:for-item="part" wx:key="index3">
                    <text class="{{part.bold ? 'ai-bold' : ''}}">{{part.text}}</text>
                  </block>
                </view>
              </view>
            </block>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="card empty-state" wx:elif="{{!loading}}">
    <text>本周暂无报告</text>
    <text>需要至少记录几天血压数据</text>
    <button class="btn-secondary" style="margin-top: 24rpx;"
      bindtap="generate" loading="{{generating}}" disabled="{{generating}}">
      {{generating ? '生成中...' : '生成周报'}}
    </button>
  </view>

  <disclaimer></disclaimer>
</view>
