<view class="container">
  <!-- 周选择 -->
  <view class="week-selector">
    <view class="week-arrow" bindtap="prevWeek">◀</view>
    <view class="week-label">{{weekStart}} ~ {{weekEnd}}</view>
    <view class="week-arrow" bindtap="nextWeek">▶</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>

  <!-- 生成按钮 -->
  <view class="generate-wrap" wx:elif="{{!report}}">
    <button class="btn-primary" bindtap="generateReport" loading="{{generating}}">
      {{generating ? '正在生成报告...' : '生成本周报告'}}
    </button>
  </view>

  <!-- 报告内容 -->
  <view wx:else>
    <!-- 概览卡片 -->
    <view class="card">
      <text class="section-title">本周概览</text>
      <view class="overview-grid">
        <view class="overview-item">
          <text class="overview-value">{{report.avg_systolic}}/{{report.avg_diastolic}}</text>
          <text class="overview-label">平均血压</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.reading_count}}次</text>
          <text class="overview-label">测量次数</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.compliance_rate}}%</text>
          <text class="overview-label">达标率</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{report.time_in_range}}%</text>
          <text class="overview-label">目标内时长</text>
        </view>
      </view>
    </view>

    <!-- 早晚对比 -->
    <view class="card" wx:if="{{report.morning_avg_sys || report.evening_avg_sys}}">
      <text class="section-title">早晚均值对比</text>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-value">{{report.morning_avg_sys != null ? report.morning_avg_sys : '--'}}</text>
          <text class="stat-label">早晨收缩压</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{report.evening_avg_sys != null ? report.evening_avg_sys : '--'}}</text>
          <text class="stat-label">晚上收缩压</text>
        </view>
      </view>
    </view>

    <!-- 波动情况 -->
    <view class="card" wx:if="{{report.max_systolic}}">
      <text class="section-title">波动情况</text>
      <view class="info-row">
        <text>最高：{{report.max_systolic}}/{{report.max_diastolic}}</text>
      </view>
      <view class="info-row">
        <text>最低：{{report.min_systolic}}/{{report.min_diastolic}}</text>
      </view>
      <view class="info-row">
        <text>波动（标准差）：收缩压±{{report.std_systolic}}，舒张压±{{report.std_diastolic}}</text>
      </view>
    </view>

    <!-- AI 分析 -->
    <view class="card" wx:if="{{report.trend_summary}}">
      <text class="section-title">AI 综合分析</text>
      <view class="analysis-text">{{report.trend_summary}}</view>
    </view>
  </view>

  <disclaimer></disclaimer>
</view>
