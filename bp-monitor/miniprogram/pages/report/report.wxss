.week-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.week-arrow {
  font-size: 28rpx;
  color: var(--primary);
}

.week-arrow.disabled { color: #ccc; }

.week-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.overview-item {
  text-align: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.overview-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.overview-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.compare-row {
  display: flex;
  gap: 24rpx;
}

.compare-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.compare-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.compare-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.volatility-row text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.volatility-detail {
  margin-top: 8rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

.analysis-content {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}
