.week-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.week-arrow {
  font-size: 28rpx;
  color: var(--primary);
}

.week-arrow.disabled { color: #ccc; }

.week-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.overview-item {
  text-align: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.overview-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.overview-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.compare-row {
  display: flex;
  gap: 24rpx;
}

.compare-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.compare-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.compare-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.volatility-row text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.volatility-detail {
  margin-top: 8rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

/* ── AI 周报头部卡片 ── */
.ai-card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 0;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  padding-bottom: 20rpx;
}

.ai-header-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 40rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.ai-header-text {
  display: flex;
  flex-direction: column;
}

.ai-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.ai-header-sub {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

/* ── AI 分区卡片 ── */
.ai-section {
  margin-top: 0;
  border-radius: 0;
  padding: 28rpx 32rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.ai-section:last-child {
  border-bottom-left-radius: var(--radius);
  border-bottom-right-radius: var(--radius);
  margin-bottom: 24rpx;
}

.ai-section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.ai-section-icon {
  font-size: 36rpx;
}

.ai-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.ai-section-body {
  padding-left: 8rpx;
}

.ai-line {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.ai-line:last-child {
  margin-bottom: 0;
}

.ai-dot {
  color: var(--primary);
  font-weight: 700;
  font-size: 28rpx;
  line-height: 1.7;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.ai-line-parts {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  flex: 1;
}

.ai-bold {
  font-weight: 700;
  color: var(--text);
}
