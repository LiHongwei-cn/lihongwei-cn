.container {
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  display: block;
}

.bp-input {
  font-size: 56rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: #aaa;
  font-weight: 400;
}

.period-selector {
  display: flex;
  gap: 16rpx;
}

.period-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  background: #fff;
}

.period-btn:active { background: #f0f0f0; }

.period-active {
  border-color: var(--primary);
  background: #e6f4ea;
  color: var(--primary);
  font-weight: 600;
}

.submit-wrap {
  padding: 0 24rpx;
  margin: 32rpx 0;
}

.analysis-content {
  font-size: 30rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}
