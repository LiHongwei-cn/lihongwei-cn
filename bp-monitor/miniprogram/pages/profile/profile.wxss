.container {
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #eee;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

.picker-display {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.target-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.target-input {
  flex: 1;
  text-align: center;
}

.target-sep {
  font-size: 48rpx;
  font-weight: 300;
  color: #ccc;
}

.med-list {
  margin-bottom: 16rpx;
}

.med-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.med-row {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.med-input {
  flex: 2;
  height: 64rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
}

.med-dose {
  flex: 1;
}

.med-time-picker {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 26rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  white-space: nowrap;
  padding: 0 8rpx;
}

.med-del {
  color: var(--danger);
  font-size: 26rpx;
  flex-shrink: 0;
}

.save-wrap {
  padding: 0 24rpx;
  margin: 32rpx 0;
}

.disclaimer-card {
  margin-bottom: 24rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #888;
  line-height: 1.8;
  white-space: pre-wrap;
}

.logout-wrap {
  padding: 0 24rpx;
}

.btn-logout {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
}
