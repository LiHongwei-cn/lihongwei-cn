<view class="container">
  <view class="greeting card">
    <text class="greeting-text">{{greeting}}</text>
    <text class="date-text">{{todayDate}}</text>
  </view>

  <view class="loading-text" wx:if="{{loading}}">加载中...</view>

  <view class="card" wx:elif="{{latestReading}}">
    <text class="section-title">最近一次测量</text>
    <bp-card
      systolic="{{latestReading.systolic}}"
      diastolic="{{latestReading.diastolic}}"
      heartRate="{{latestReading.heart_rate}}"
      measuredAt="{{latestReading.measured_at}}"
      timePeriod="{{latestReading.time_period}}"
      bpLevel="{{latestReading.bp_level}}"
      notes="{{latestReading.notes}}"
    />
  </view>

  <view class="card empty-state" wx:else>
    <text>还没有记录血压</text>
    <text>点击下方按钮开始记录</text>
  </view>

  <view class="record-btn-wrap">
    <button class="btn-primary" bindtap="goRecord">记录血压</button>
  </view>

  <view class="nav-grid">
    <view class="nav-item" bindtap="goHistory">
      <view class="nav-icon nav-icon-history">史</view>
      <text class="nav-label">历史记录</text>
    </view>
    <view class="nav-item" bindtap="goReport">
      <view class="nav-icon nav-icon-report">报</view>
      <text class="nav-label">周报分析</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <view class="nav-icon nav-icon-profile">我</view>
      <text class="nav-label">健康档案</text>
    </view>
  </view>

  <view class="card" wx:if="{{!loading && stats.reading_count}}">
    <text class="section-title">本周统计</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.avg_systolic}}/{{stats.avg_diastolic}}</text>
        <text class="stat-label">平均血压</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.reading_count}}次</text>
        <text class="stat-label">{{stats.days_with_readings}}天记录</text>
      </view>
    </view>
    <view class="trend trend-{{stats.trend_direction}}">
      <text wx:if="{{stats.trend_direction === 'improving'}}">趋势向好，收缩压较前段下降</text>
      <text wx:elif="{{stats.trend_direction === 'worsening'}}">注意：收缩压较前段升高</text>
      <text wx:elif="{{stats.trend_direction === 'stable'}}">血压稳定，继续保持</text>
      <text wx:else>数据不足，继续记录以获取趋势分析</text>
    </view>
  </view>

  <disclaimer></disclaimer>
</view>
