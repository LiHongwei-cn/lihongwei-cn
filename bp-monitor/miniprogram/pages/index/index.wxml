<view class="container">
  <!-- 问候语 -->
  <view class="greeting card">
    <text class="greeting-text">{{greeting}}</text>
    <text class="date-text">{{todayDate}}</text>
  </view>

  <!-- 登录 / 连接错误 -->
  <view class="card login-error" wx:if="{{loginError}}">
    <text class="login-error-title">连接失败</text>
    <text class="login-error-detail">{{loginError}}</text>
    <view class="login-error-tips">
      <text class="login-error-tip-title">常见原因：</text>
      <text class="login-error-tip">1. 云函数未部署 → 微信开发者工具中右键 cloudfunctions/api → 上传并部署</text>
      <text class="login-error-tip">2. 云开发环境未开通 → 点击工具栏「云开发」按钮开通</text>
      <text class="login-error-tip">3. 环境ID不匹配 → 确认 app.js 中的 env 与云开发控制台一致</text>
    </view>
    <button class="btn-primary" style="margin-top: 20rpx;" bindtap="retryLogin">重新连接</button>
  </view>

  <!-- 加载中 -->
  <view class="loading-text" wx:elif="{{loading}}">加载中...</view>

  <!-- 最新读数 -->
  <view class="card" wx:elif="{{latestReading}}">
    <text class="section-title">最近一次测量</text>
    <bp-card
      readingId="{{latestReading._id}}"
      systolic="{{latestReading.systolic}}"
      diastolic="{{latestReading.diastolic}}"
      heartRate="{{latestReading.heartRate}}"
      measuredAt="{{latestReading.measuredAt}}"
      timePeriod="{{latestReading.timePeriod}}"
      bpLevel="{{latestReading.bpLevel}}"
      notes="{{latestReading.notes}}"
      bind:delete="onDeleteReading"
    />
  </view>

  <!-- 无读数 -->
  <view class="card empty-state" wx:elif="{{!loading && !loginError}}">
    <text>还没有记录血压</text>
    <text>点击下方按钮开始记录</text>
  </view>

  <!-- 快速记录入口 -->
  <view class="quick-record" wx:if="{{!loginError && !loading}}">
    <button class="btn-primary btn-record" bindtap="goRecord">+ 记录血压</button>
  </view>

  <!-- 本周统计 -->
  <view class="card" wx:if="{{!loading && !loginError && stats.readingCount}}">
    <text class="section-title">本周统计</text>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.avgSystolic}}/{{stats.avgDiastolic}}</text>
        <text class="stat-label">平均血压</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.readingCount}}次</text>
        <text class="stat-label">{{stats.daysWithReadings}}天记录</text>
      </view>
    </view>
    <view class="trend-card trend-{{stats.trendDirection}}">
      <view class="trend-icon-wrap">
        <text class="trend-icon">{{stats.trendIcon}}</text>
      </view>
      <view class="trend-content">
        <text class="trend-title">{{stats.trendTitle}}</text>
        <text class="trend-desc">{{stats.trendDesc}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="nav-grid" wx:if="{{!loginError && !loading}}">
    <view class="nav-item" bindtap="goHistory">
      <view class="nav-icon nav-icon-history">📋</view>
      <text class="nav-label">历史记录</text>
    </view>
    <view class="nav-item" bindtap="goReport">
      <view class="nav-icon nav-icon-report">📊</view>
      <text class="nav-label">周报分析</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <view class="nav-icon nav-icon-profile">👤</view>
      <text class="nav-label">健康档案</text>
    </view>
  </view>

  <disclaimer wx:if="{{!loginError}}"></disclaimer>
</view>
