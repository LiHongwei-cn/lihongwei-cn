.container {
  padding-bottom: 40rpx;
}

.greeting {
  text-align: center;
  padding: 40rpx 32rpx;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.date-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.record-btn-wrap {
  padding: 0 24rpx;
  margin: 32rpx 0;
}

.stats-row {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  display: block;
}

.trend-indicator {
  margin-top: 20rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  text-align: center;
}

.trend-improving { background: #e6f4ea; color: #2c7a4f; }
.trend-worsening { background: #fce8e6; color: #d93025; }
.trend-stable { background: #e8f0fe; color: #1a73e8; }

/* 快捷入口 */
.nav-grid {
  display: flex;
  padding: 0 24rpx;
  margin-bottom: 8rpx;
  gap: 16rpx;
}

.nav-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 16rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.nav-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.nav-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}
