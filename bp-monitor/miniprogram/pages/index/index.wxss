.greeting {
  background: linear-gradient(135deg, #2c7a4f 0%, #3d9a63 100%);
  color: #fff;
  padding: 40rpx 32rpx;
}

.greeting-text {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.date-text {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  display: block;
}

.quick-record {
  margin: 0 24rpx 24rpx;
}

.btn-record {
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2c7a4f 0%, #3d9a63 100%);
  box-shadow: 0 8rpx 24rpx rgba(44, 122, 79, 0.3);
}

.btn-record:active {
  transform: scale(0.98);
}

.nav-grid {
  display: flex;
  margin: 0 24rpx 24rpx;
  gap: 16rpx;
}

.nav-item {
  flex: 1;
  background: #fff;
  border-radius: var(--radius);
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.nav-item:active {
  background: #f5f5f5;
  transform: scale(0.96);
}

.nav-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  font-size: 36rpx;
  background: #f5f5f5;
}

.nav-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stats-row {
  display: flex;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.trend-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.trend-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trend-icon {
  font-size: 36rpx;
}

.trend-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.trend-title {
  font-size: 28rpx;
  font-weight: 700;
}

.trend-desc {
  font-size: 24rpx;
  opacity: 0.8;
  line-height: 1.5;
}

.trend-improving {
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
  border: 1rpx solid #c8e6c9;
}
.trend-improving .trend-icon-wrap { background: #c8e6c9; }
.trend-improving .trend-title { color: #2e7d32; }
.trend-improving .trend-desc { color: #4caf50; }

.trend-worsening {
  background: linear-gradient(135deg, #fce4ec 0%, #fff3e0 100%);
  border: 1rpx solid #ffcdd2;
}
.trend-worsening .trend-icon-wrap { background: #ffcdd2; }
.trend-worsening .trend-title { color: #c62828; }
.trend-worsening .trend-desc { color: #e57373; }

.trend-stable {
  background: linear-gradient(135deg, #e3f2fd 0%, #e8f5e9 100%);
  border: 1rpx solid #bbdefb;
}
.trend-stable .trend-icon-wrap { background: #bbdefb; }
.trend-stable .trend-title { color: #1565c0; }
.trend-stable .trend-desc { color: #64b5f6; }

.trend-insufficient_data {
  background: #fafafa;
  border: 1rpx solid #eee;
}
.trend-insufficient_data .trend-icon-wrap { background: #eee; }
.trend-insufficient_data .trend-title { color: #999; }
.trend-insufficient_data .trend-desc { color: #bbb; }

.login-error {
  background: #fff3f0;
  border: 2rpx solid #fce8e6;
}

.login-error-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--danger);
  margin-bottom: 12rpx;
}

.login-error-detail {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  word-break: break-all;
}

.login-error-tips {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
}

.login-error-tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.login-error-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}
