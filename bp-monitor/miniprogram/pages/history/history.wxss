.container {
  padding-bottom: 40rpx;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.filter-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  color: #666;
}

.filter-active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.load-more {
  padding: 32rpx 24rpx;
  text-align: center;
}
