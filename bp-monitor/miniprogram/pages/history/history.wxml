<view class="container">
  <!-- 日期筛选 -->
  <view class="filter-bar">
    <view
      class="filter-btn {{filterDays === 7 ? 'filter-active' : ''}}"
      bindtap="setFilter" data-days="7"
    >7天</view>
    <view
      class="filter-btn {{filterDays === 30 ? 'filter-active' : ''}}"
      bindtap="setFilter" data-days="30"
    >30天</view>
    <view
      class="filter-btn {{filterDays === 90 ? 'filter-active' : ''}}"
      bindtap="setFilter" data-days="90"
    >90天</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-text" wx:if="{{loading}}"><text>加载中...</text></view>

  <!-- 读数列表 -->
  <view wx:if="{{readings.length > 0}}" wx:else>
    <view wx:for="{{readings}}" wx:key="id">
      <bp-card
        systolic="{{item.systolic}}"
        diastolic="{{item.diastolic}}"
        heartRate="{{item.heart_rate}}"
        measuredAt="{{item.measured_at}}"
        timePeriod="{{item.time_period}}"
        bpLevel="{{item.bp_level}}"
        notes="{{item.notes}}"
        aiAnalysis="{{item.ai_analysis}}"
        showAnalysis="{{expandedId === item.id}}"
        bindtap="toggleAnalysis"
        data-id="{{item.id}}"
      />
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text>暂无记录</text>
    <text>快去记录您的第一次血压吧</text>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <button class="btn-secondary" bindtap="loadMore">加载更多</button>
  </view>

  <disclaimer></disclaimer>
</view>
