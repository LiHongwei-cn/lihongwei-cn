.bp-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bp-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bp-time {
  font-size: 26rpx;
  color: #666;
}

.bp-period {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.bp-card-values {
  display: flex;
  align-items: flex-end;
}

.bp-value-item {
  flex: 1;
  text-align: center;
}

.bp-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

.bp-card-notes {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #888;
}

.bp-card-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bp-delete {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.bp-delete:active {
  color: #e74c3c;
  border-color: #e74c3c;
}

.bp-card-analysis {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}
