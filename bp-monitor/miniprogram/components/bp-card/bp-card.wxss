.bp-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bp-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bp-time {
  font-size: 26rpx;
  color: #666;
}

.bp-period {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.bp-card-values {
  display: flex;
  align-items: flex-end;
}

.bp-value-item {
  flex: 1;
  text-align: center;
}

.bp-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

.bp-card-notes {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #888;
}

.bp-card-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bp-delete {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.bp-delete:active {
  color: #e74c3c;
  border-color: #e74c3c;
}

/* ── AI 分析区域 ── */
.bp-card-analysis {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0f7f4 0%, #e8f0eb 100%);
  border-radius: 16rpx;
  border: 1rpx solid #d4e8dc;
}

.analysis-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #2c7a4f 0%, #3d9a63 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.analysis-section {
  margin-bottom: 20rpx;
}

.analysis-section:last-child {
  margin-bottom: 0;
}

.analysis-section-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.analysis-section-icon {
  font-size: 28rpx;
}

.analysis-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a3a25;
}

.analysis-section-body {
  padding-left: 36rpx;
}

.analysis-line {
  font-size: 26rpx;
  line-height: 1.7;
  color: #4a6655;
  margin-bottom: 6rpx;
}

.analysis-line:last-child {
  margin-bottom: 0;
}

.analysis-bold {
  font-weight: 700;
  color: #1a3a25;
}
