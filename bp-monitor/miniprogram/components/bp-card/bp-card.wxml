<wxs src="../../utils/md.wxs" module="md" />

<view class="bp-card">
  <view class="bp-card-header">
    <view class="bp-time">
      <text>{{displayTime}}</text>
      <text class="bp-period" wx:if="{{periodLabel}}">{{periodLabel}}</text>
    </view>
    <view class="bp-card-header-right">
      <view class="badge badge-{{levelClass}}">{{bpLevel || '未分类'}}</view>
      <text class="bp-delete" catchtap="onDelete">删除</text>
    </view>
  </view>

  <view class="bp-card-values">
    <view class="bp-value-item">
      <text class="bp-number {{levelClass}}">{{systolic}}</text>
      <text class="bp-label">收缩压</text>
    </view>
    <view class="bp-divider"></view>
    <view class="bp-value-item">
      <text class="bp-number {{levelClass}}">{{diastolic}}</text>
      <text class="bp-label">舒张压</text>
    </view>
    <view class="bp-divider" wx:if="{{heartRate}}"></view>
    <view class="bp-value-item" wx:if="{{heartRate}}">
      <text class="bp-number bp-normal">{{heartRate}}</text>
      <text class="bp-label">心率</text>
    </view>
  </view>

  <view class="bp-card-notes" wx:if="{{notes}}">
    <text>备注：{{notes}}</text>
  </view>

  <view class="bp-card-analysis" wx:if="{{showAnalysis && aiAnalysis}}">
    <view class="analysis-tag">AI 分析</view>
    <block wx:for="{{md.parseSections(aiAnalysis).sections}}" wx:key="index">
      <view class="analysis-section">
        <view class="analysis-section-head">
          <text class="analysis-section-icon">{{item.icon}}</text>
          <text class="analysis-section-title">{{item.title}}</text>
        </view>
        <view class="analysis-section-body">
          <block wx:for="{{item.lines}}" wx:for-item="line" wx:key="idx">
            <view class="analysis-line">
              <block wx:for="{{line.parts}}" wx:for-item="part" wx:key="idx2">
                <text class="{{part.bold ? 'analysis-bold' : ''}}">{{part.text}}</text>
              </block>
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>
</view>
