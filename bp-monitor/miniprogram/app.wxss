page {
  --primary: #2c7a4f;
  --danger: #d93025;
  --warning: #e37400;
  --text: #1a1a1a;
  --text-secondary: #666666;
  --bg: #f5f5f5;
  --card-bg: #ffffff;
  --border: #e0e0e0;
  --radius: 16rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.6;
}

/* ── 通用卡片 ── */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* ── 大号按钮 ── */
.btn-primary {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--primary);
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: var(--radius);
  border: none;
  text-align: center;
}

.btn-primary:active { opacity: 0.85; }

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

.btn-secondary {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: var(--primary);
  font-size: 32rpx;
  border: 2rpx solid var(--primary);
  border-radius: var(--radius);
  text-align: center;
}

/* ── 大号数字显示 ── */
.bp-number {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 4rpx;
}

.bp-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.bp-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ── 颜色状态 ── */
.bp-normal { color: var(--primary); }
.bp-elevated { color: var(--warning); }
.bp-high { color: var(--danger); }

/* ── 标签/徽章 ── */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-normal { background: #e6f4ea; color: var(--primary); }
.badge-elevated { background: #fef7e0; color: var(--warning); }
.badge-high { background: #fce8e6; color: var(--danger); }

/* ── 表单输入 ── */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  font-size: 40rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  background: var(--card-bg);
  box-sizing: border-box;
}

.form-input:focus { border-color: var(--primary); }

.form-input-error { border-color: var(--danger); }

.form-error-text {
  font-size: 24rpx;
  color: var(--danger);
  margin-top: 8rpx;
}

/* ── 加载 ── */
.loading-text {
  text-align: center;
  color: var(--text-secondary);
  padding: 48rpx;
  font-size: 30rpx;
}

/* ── 空状态 ── */
.empty-state {
  text-align: center;
  padding: 80rpx 48rpx;
}

.empty-state text {
  display: block;
  color: var(--text-secondary);
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

/* ── 免责声明 ── */
.disclaimer-bar {
  text-align: center;
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #999;
  background: #fafafa;
  border-top: 1rpx solid var(--border);
}
