#!/bin/bash
# ============================================================
#  MUNDO — THE EMPEROR 启动器
#  智能定位蒙多目录并启动 mundo.py
# ============================================================

# ---- 智能定位蒙多代码目录 ----
find_mundo_dir() {
    local candidates=(
        "$HOME/蒙多"
        "$HOME/Desktop/lihongwei-cn/mundo-agent"
        "$HOME/.hermes/mundo-agent"
        "$HOME/Desktop/mundo-agent"
        "$HOME/mundo-agent"
    )
    
    for dir in "${candidates[@]}"; do
        [ -f "$dir/mundo.py" ] && { echo "$dir"; return; }
    done
    
    local found
    found=$(find "$HOME" -maxdepth 5 -name "mundo.py" -not -path "*/node_modules/*" -not -path "*/.git/*" -not -path "*/venv/*" 2>/dev/null | head -1)
    [ -n "$found" ] && { dirname "$found"; return; }
    
    return 1
}

# ---- 定位蒙多目录 ----
MUNDO_DIR=$(find_mundo_dir)
if [ -z "$MUNDO_DIR" ]; then
    osascript -e 'display dialog "❌ 找不到蒙多主程序 (mundo.py)\n\n请确保蒙多代码已正确安装。" buttons {"确定"} default button "确定" with icon stop with title "MUNDO — THE EMPEROR"'
    exit 1
fi

# ---- 定位Python ----
PYTHON=""
[ -f "$MUNDO_DIR/venv/bin/python3" ] && PYTHON="$MUNDO_DIR/venv/bin/python3"
[ -z "$PYTHON" ] && PYTHON="python3"

# ---- 关键：检测是否有终端，没有则用Terminal.app打开 ----
if [ ! -t 0 ] || [ ! -t 1 ]; then
    # 从Finder启动，没有终端 → 创建临时脚本让Terminal执行
    TEMP_SCRIPT="/tmp/mundo-launch-$$.sh"
    cat > "$TEMP_SCRIPT" << EOF
#!/bin/bash
cd "$MUNDO_DIR"
export PYTHONPATH="$MUNDO_DIR:\$PYTHONPATH"
export MUNDO_HOME="$MUNDO_DIR"
export MUNDO_LAUNCHED_FROM="app"
export PYTHONIOENCODING="utf-8"
export LANG="zh_CN.UTF-8"
export PYTHONDONTWRITEBYTECODE=1

# 检查依赖
for pkg in requests rich prompt_toolkit; do
    $PYTHON -c "import \$pkg" 2>/dev/null || $PYTHON -m pip install "\$pkg" --quiet 2>/dev/null
done

echo -ne "\033]0;MUNDO — THE EMPEROR\007"

exec $PYTHON mundo.py
EOF
    chmod +x "$TEMP_SCRIPT"
    
    # 用Terminal.app执行临时脚本
    osascript << EOF
tell application "Terminal"
    activate
    do script "$TEMP_SCRIPT"
end tell
EOF
    
    # 延迟删除临时脚本
    (sleep 60 && rm -f "$TEMP_SCRIPT") &
    exit 0
fi

# ---- 以下是终端模式（直接运行） ----
cd "$MUNDO_DIR"
export PYTHONPATH="$MUNDO_DIR:$PYTHONPATH"
export MUNDO_HOME="$MUNDO_DIR"
export MUNDO_LAUNCHED_FROM="app"
export PYTHONIOENCODING="utf-8"
export LANG="zh_CN.UTF-8"
export PYTHONDONTWRITEBYTECODE=1

# 检查依赖
for pkg in requests rich prompt_toolkit; do
    $PYTHON -c "import $pkg" 2>/dev/null || $PYTHON -m pip install "$pkg" --quiet 2>/dev/null
done

exec $PYTHON mundo.py
