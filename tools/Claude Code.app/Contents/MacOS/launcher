#!/bin/bash
export CLAUDE_CODE_ENTRYPOINT=cli
WORK_DIR="$HOME/Desktop/lihongwei-ch"

cd "$WORK_DIR" || exit 1

if ! command -v claude &> /dev/null; then
    osascript -e 'display dialog "claude 命令未找到，请先安装 Claude Code。\n\n安装方法：\n  brew install claude-code\n  npm install -g @anthropic-ai/claude-code" buttons {"OK"} default button "OK" with icon stop'
    exit 1
fi

osascript -e "tell application \"Terminal\" to do script \"cd '$WORK_DIR' && export CLAUDE_CODE_ENTRYPOINT=cli && claude --dangerously-skip-permissions --no-chrome; exit\""
